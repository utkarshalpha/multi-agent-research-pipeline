# --- Required API keys (not needed when MOCK_MODE is on) ---
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# --- Mock / offline mode ---
# Set to 1/true/yes (case-insensitive) to run the ENTIRE pipeline offline with
# deterministic mocks: no network calls and no API keys required. /health and
# response metadata then label the model as e.g. "mock (claude-sonnet-4-6)".
MOCK_MODE=false

# --- LangSmith tracing (optional but recommended) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=research-pipeline

# --- Model selection ---
# The original spec named claude-3-5-sonnet, which is retired. Defaults to the
# current Sonnet tier. Set to claude-opus-4-8 for the most capable tier.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Infrastructure endpoints ---
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379

# No Docker? Set QDRANT_PATH to run Qdrant embedded (in-process, on-disk, no
# server). This makes the semantic cache work without docker-compose.
# Leave empty to use QDRANT_URL above (the docker-compose setup).
QDRANT_PATH=./qdrant_local
# Docker Qdrant mode: set QDRANT_PATH= and keep QDRANT_URL=http://localhost:6333

# --- Embeddings / vector store ---
# Local fastembed model (no API key needed). The spec's 1536 dims assumed
# OpenAI embeddings; bge-small is 384 dims. Change both together if you swap.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
VECTOR_SIZE=384
QDRANT_COLLECTION=research_cache
CACHE_SIMILARITY_THRESHOLD=0.85

# --- Pipeline tuning ---
CONFIDENCE_PASS_THRESHOLD=0.7
MAX_RETRIES=2
TAVILY_MAX_RESULTS=5
TAVILY_TIMEOUT_SECONDS=10
ARXIV_MAX_RESULTS=3
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# --- API hardening ---
# Hard wall-clock limit for a single /research run, in seconds.
RESEARCH_TIMEOUT_SECONDS=300
# Static API key the FastAPI layer requires from clients. Empty = auth disabled.
PIPELINE_API_KEY=
# Max /research requests per minute per client. 0 = rate limiting disabled.
RATE_LIMIT_PER_MINUTE=0
